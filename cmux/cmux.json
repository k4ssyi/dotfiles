{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,
  // マウス選択を確定した時点で自動的にクリップボードへコピー (tmux copy-pipe 相当)
  "terminal": {
    "copyOnSelect": true
  },
  // Tmux like keybindings
  "shortcuts": {
    "bindings": {
      // --- ペイン (cmux split pane) ---
      "splitRight": ["ctrl+b", "\\"],       // tmux: prefix \  左右分割
      "splitDown": ["ctrl+b", "-"],         // tmux: prefix -  上下分割
      "focusLeft": ["ctrl+b", "shift+h"],   // ペインフォーカス 左
      "focusDown": ["ctrl+b", "shift+j"],   // ペインフォーカス 下
      "focusUp": ["ctrl+b", "shift+k"],     // ペインフォーカス 上
      "focusRight": ["ctrl+b", "shift+l"],  // ペインフォーカス 右
      "toggleSplitZoom": ["ctrl+b", "z"],   // tmux: prefix z  ペインズーム
      "equalizeSplits": ["ctrl+b", "="],    // ペインサイズ均等化 (リサイズ代替)

      // --- ウィンドウ (cmux surface / タブ) ---
      "newSurface": ["ctrl+b", "c"],        // tmux: prefix c  新規ウィンドウ(タブ)
      "prevSurface": ["ctrl+b", "h"],       // 前のタブ(surface)
      "nextSurface": ["ctrl+b", "l"],       // 次のタブ(surface)
      "closeTab": ["ctrl+b", "x"],          // tmux: prefix x  閉じる

      // --- セッション (cmux workspace) ---
      "goToWorkspace": ["ctrl+b", "w"],     // ワークスペース選択
      "nextSidebarTab": ["ctrl+b", "j"],    // 次のワークスペース
      "prevSidebarTab": ["ctrl+b", "k"],    // 前のワークスペース
      "commandPalette": ["ctrl+b", "o"],    // コマンドパレット

      // --- その他 ---
      // コピーモードはデフォルト (Cmd+Shift+M) を使用。Ctrl+b [ へのリマップは
      // v(選択)/y(コピー) が機能しない事象のため一旦解除。
      "reloadConfiguration": ["ctrl+b", "r"]     // tmux: prefix r  設定リロード
    }
  }
}
